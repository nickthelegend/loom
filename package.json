{
  "name": "loom-agents",
  "version": "0.1.0",
  "description": "Loom — local-first control plane for coding agents: one CLI, shared memory, baton handoffs across Claude Code, OpenCode, and friends.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Nivesh Gajengi <niveshgajengi@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/nickthelegend/loom.git"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "bin": {
    "loom": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./sdk": "./dist/sdk.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "express": "^5.2.1",
    "picocolors": "^1.1.1",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.1",
    "typescript": "~5.9.0",
    "vitest": "^4.1.10"
  }
}
