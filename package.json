{
  "name": "threadloom",
  "version": "0.1.0",
  "description": "Loom — local-first control plane for coding agents: one CLI, shared memory, baton handoffs and routes across Claude Code, OpenCode, and friends.",
  "type": "module",
  "license": "MIT",
  "author": "Nivesh Gajengi <niveshgajengi@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickthelegend/loom.git"
  },
  "homepage": "https://github.com/nickthelegend/loom#readme",
  "bugs": "https://github.com/nickthelegend/loom/issues",
  "keywords": [
    "ai-agents",
    "claude-code",
    "opencode",
    "orchestration",
    "cli",
    "tui",
    "llm",
    "routing",
    "tailscale"
  ],
  "files": [
    "dist",
    "docs",
    "CHANGELOG.md",
    "ARCHITECTURE.md"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "bin": {
    "loom": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./sdk": "./dist/sdk.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "commander": "^15.0.0",
    "express": "^5.2.1",
    "ink": "^7.1.0",
    "picocolors": "^1.1.1",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.7",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.17",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.1",
    "typescript": "~5.9.0",
    "vitest": "^4.1.10"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  }
}
