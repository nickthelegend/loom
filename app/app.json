{
  "expo": {
    "name": "Loom",
    "slug": "loom",
    "version": "0.1.0",
    "scheme": "loom",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0b0e14",
    "splash": {
      "backgroundColor": "#0b0e14"
    },
    "ios": {
      "bundleIdentifier": "dev.loom.app",
      "supportsTablet": false
    },
    "android": {
      "package": "dev.loom.app"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Loom uses the microphone for voice input",
          "speechRecognitionPermission": "Loom converts your speech to text so you can dictate messages"
        }
      ]
    ]
  }
}
